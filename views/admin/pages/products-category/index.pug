extends ../../layouts/default.pug
include ../../mixins/table-tree.pug

block main
  h1 Product Categories

  .card.mb-3
    .card-header List
    .card-body
      .row
        .col-8
        .col-4
          a(
            href=`${prefixAdmin}/products/categories/create`
            class="btn btn-outline-success"
          ) + Create

      table(
        class="table table-hover table-sm"
        checkbox-multi
      )
        thead
          tr
            td
              input(type="checkbox" name="checkall")
            th No.
            th Image
            th Title
            th Position
            th Status
            th Actions

        tbody
          +table-tree(records)
