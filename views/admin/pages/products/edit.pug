extends ../../layouts/default.pug 

include ../../mixins/alert.pug

block main 
    +alert-success(3000)
    +alert-error(5000)

    div(class="container-fluid pt-3")
        div(class="card mb-4 shadow-sm border-0")
            div(class="card-header bg-primary text-white d-flex align-items-center justify-content-between")
                h5(class="mb-0")
                    i(class="fas fa-plus-circle me-2")
                    | Chỉnh sửa sản phẩm
                a(href=`${prefixAdmin}/products` class="btn btn-sm btn-light")
                    i(class="fas fa-arrow-left me-1")
                    | Quay lại

            div(class="card-body p-4")
                form(
                    action=`${prefixAdmin}/products/edit/${product.id}?_method=PATCH`
                    id="form-edit-product"
                    method="POST"
                    enctype="multipart/form-data"
                )
                    div(class="row")
                        // Left Column: Basic Information
                        div(class="col-md-7")
                            div(class="card border shadow-none mb-3")
                                div(class="card-header bg-light fw-bold")
                                    i(class="fas fa-info-circle me-2")
                                    | Thông tin cơ bản
                                div(class="card-body")
                                    div(class="form-group mb-3")
                                        label(for="title" class="form-label fw-bold") Tiêu đề sản phẩm
                                        input(
                                            type="text"
                                            class="form-control form-control-lg"
                                            id="title"
                                            name="title"
                                            required
                                            value=product.title
                                            placeholder="Nhập tên sản phẩm..."
                                        )
                                    
                                    div(class="form-group mb-0")
                                        label(for="desc" class="form-label fw-bold") Mô tả chi tiết
                                        textarea(
                                            class="form-control"
                                            id="desc"
                                            name="description"
                                            rows="8"
                                            placeholder="Nhập mô tả sản phẩm..."
                                        ) #{product.description}
                        
                        // Right Column: Media & Settings
                        div(class="col-md-5")
                            // Image Upload Card
                            div(class="card border shadow-none mb-3")
                                div(class="card-header bg-light fw-bold")
                                    i(class="fas fa-image me-2")
                                    | Hình ảnh sản phẩm
                                div(class="card-body")
                                    div(class="form-group mb-0" upload-image)
                                        label(for="thumbnail" class="form-label d-block text-muted small mb-2") Tải lên ảnh mới để thay đổi
                                        input(
                                            type="file"
                                            class="form-control mb-3"
                                            id="thumbnail"
                                            name="thumbnail"
                                            accept="image/*"
                                            upload-image-input
                                        )
                                        div(class="image-preview-wrapper d-inline-block position-relative border rounded p-1 bg-white")
                                            img(
                                                src=product.thumbnail
                                                upload-image-preview
                                                class="image-preview mt-0"
                                                style=(product.thumbnail ? "max-width: 200px; display: block" : "max-width: 200px; display: none")
                                            )
                                            span(
                                                close-image-preview 
                                                class="btn btn-danger btn-sm position-absolute top-0 start-0 translate-middle badge rounded-pill" 
                                                style=(product.thumbnail ? "display: inline-block; cursor: pointer;" : "display: none; cursor: pointer;")
                                            ) 
                                                i(class="fas fa-times")

                            // Settings Card
                            div(class="card border shadow-none")
                                div(class="card-header bg-light fw-bold")
                                    i(class="fas fa-cog me-2")
                                    | Cấu hình khác
                                div(class="card-body")
                                    div(class="form-group mb-0")
                                        label(for="position" class="form-label fw-bold") Vị trí hiển thị
                                        div(class="input-group")
                                            span(class="input-group-text")
                                                i(class="fas fa-sort-numeric-down")
                                            input(
                                                type="number"
                                                class="form-control"
                                                id="position"
                                                name="position"
                                                placeholder="Tự động tăng"
                                                min="1"
                                                value=product.position
                                            )
                                        div(class="form-text text-muted") Số càng lớn hiển thị càng ưu tiên.

                    // Pricing & Stock Section
                    div(class="card border shadow-none my-3")
                        div(class="card-header bg-light fw-bold")
                            i(class="fas fa-tags me-2")
                            | Giá cả & Kho hàng
                        div(class="card-body")
                            div(class="row")
                                div(class="col-md-4")
                                    div(class="form-group mb-0")
                                        label(for="price" class="form-label fw-bold") Giá gốc
                                        div(class="input-group")
                                            span(class="input-group-text bg-success text-white") $
                                            input(
                                                type="number"
                                                class="form-control"
                                                id="price"
                                                name="price"
                                                value=product.price
                                                min="0"
                                            )
                                div(class="col-md-4")
                                    div(class="form-group mb-0")
                                        label(for="discount" class="form-label fw-bold") % Giảm giá
                                        div(class="input-group")
                                            input(
                                                type="number"
                                                class="form-control"
                                                id="discount"
                                                name="discountPercentage"
                                                value=product.discountPercentage
                                                min="0"
                                                max="100"
                                            )
                                            span(class="input-group-text bg-warning") %
                                div(class="col-md-4")
                                    div(class="form-group mb-0")
                                        label(for="stock" class="form-label fw-bold") Số lượng trong kho
                                        div(class="input-group")
                                            span(class="input-group-text bg-info text-white")
                                                i(class="fas fa-cubes")
                                            input(
                                                type="number"
                                                class="form-control"
                                                id="stock"
                                                name="stock"
                                                value=product.stock
                                                min="0"
                                            )

                    div(class="card border shadow-none mb-4")
                        div(class="card-body")
                            div(class="row align-items-center")
                                div(class="col-md-6")
                                    label(class="form-label d-block fw-bold mb-0") 
                                        i(class="fas fa-toggle-on me-2")
                                        | Trạng thái hoạt động
                                div(class="col-md-6 text-end")
                                    div(class="form-check form-check-inline")
                                        input(
                                            type="radio"
                                            class="form-check-input"
                                            id="statusActive"
                                            name="status"
                                            value="active"
                                            checked=(product.status == "active" ? true : false)
                                        )
                                        label(for="statusActive" class="form-check-label text-success fw-bold") Hoạt động 
                                    div(class="form-check form-check-inline")
                                        input(
                                            type="radio"
                                            class="form-check-input"
                                            id="statusInActive"
                                            name="status"
                                            value="inactive"
                                            checked=(product.status == "inactive" ? true : false)
                                        )
                                        label(for="statusInActive" class="form-check-label text-danger fw-bold") Dừng hoạt động
                    
                    div(class="form-group mb-0 text-center border-top pt-4")
                        button(
                            type="submit"
                            class="btn btn-primary btn-lg px-5 shadow"
                        ) 
                            i(class="fas fa-save me-2")
                            | Cập nhật dữ liệu

    script(src="/admin/js/product.js")