extends ../../layouts/default.pug

block main
    if (product)
        div(class="container-fluid pt-3")
            // Header
            div(class="card mb-4 border-0 shadow-sm")
                div(class="card-body d-flex align-items-center justify-content-between py-3")
                    div
                        h4(class="mb-0 fw-bold text-primary") Chi tiết sản phẩm
                        span(class="text-muted small") ID: #{product.id}
                    div
                        a(href=`${prefixAdmin}/products` class="btn btn-outline-secondary btn-sm me-2")
                            i(class="fas fa-arrow-left me-1")
                            | Quay lại
                        a(href=`${prefixAdmin}/products/edit/${product.id}` class="btn btn-warning btn-sm fw-bold px-3")
                            i(class="fas fa-edit me-1")
                            | Chỉnh sửa

            div(class="row")
                // Left Column: Basic Info
                div(class="col-md-8")
                    div(class="card mb-4 border-0 shadow-sm")
                        div(class="card-header bg-white fw-bold py-3")
                            i(class="fas fa-info-circle me-2 text-primary")
                            | Thông tin chi tiết
                        div(class="card-body p-4")
                            h3(class="fw-bold mb-3") #{product.title}
                            
                            div(class="mb-4")
                                label(class="form-label fw-bold text-muted") Mô tả:
                                if (product.description)
                                    div(class="product-detail-desc p-3 border rounded bg-light")
                                        | !{product.description}
                                else
                                    p(class="text-muted") Không có mô tả.
                            
                            div(class="row g-3")
                                div(class="col-sm-6")
                                    div(class="p-3 border rounded")
                                        label(class="d-block text-muted small") Vị trí hiển thị
                                        div(class="fw-bold fs-5") ##{product.position}
                                div(class="col-sm-6")
                                    div(class="p-3 border rounded")
                                        label(class="d-block text-muted small") Trạng thái
                                        if (product.status === "active")
                                            span(class="badge bg-success") Hoạt động
                                        else
                                            span(class="badge bg-danger") Dừng hoạt động

                // Right Column: Media & Pricing
                div(class="col-md-4")
                    // Media
                    div(class="card mb-4 border-0 shadow-sm overflow-hidden")
                        div(class="card-header bg-white fw-bold py-3")
                            i(class="fas fa-image me-2 text-primary")
                            | Hình ảnh
                        div(class="card-body p-0 text-center bg-light")
                            if (product.thumbnail)
                                img(
                                    src=product.thumbnail
                                    class="img-fluid w-100"
                                    style="max-height: 350px; object-fit: contain"
                                )
                            else
                                div(class="py-5 text-muted")
                                    i(class="fas fa-image fa-3x opacity-25")
                                    p(class="mt-2") Không có ảnh

                    // Pricing
                    div(class="card mb-4 border-0 shadow-sm bg-primary text-white")
                        div(class="card-body p-4")
                            div(class="mb-3")
                                label(class="opacity-75 small") Giá bán hiện tại
                                div(class="d-flex align-items-end")
                                    h2(class="mb-0 fw-bold me-2") $#{product.price}
                                    if (product.discountPercentage > 0)
                                        span(class="badge bg-danger") -#{product.discountPercentage}%
                            
                            hr(class="opacity-25")
                            
                            div(class="row")
                                div(class="col-6 border-end")
                                    label(class="opacity-75 small") Kho hàng
                                    h4(class="mb-0 fw-bold") #{product.stock}
                                div(class="col-6 ps-3")
                                    label(class="opacity-75 small") Đã bán
                                    h4(class="mb-0 fw-bold") 0

    style.
        .product-detail-desc img {
            max-width: 100%;
            height: auto;
        }
        .card {
            border-radius: 12px;
        }

    script(src="/admin/js/product.js")