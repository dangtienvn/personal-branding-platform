extends ../../layouts/default.pug 

include ../../mixins/alert.pug

block main 
    +alert-success(3000)
    +alert-error(5000)

    div(class="container-fluid pt-3")
        div(class="card mb-4 shadow-sm border-0")
            div(class="card-header bg-primary text-white d-flex align-items-center justify-content-between")
                h5(class="mb-0")
                    i(class="fas fa-plus-circle me-2")
                    | Thêm sản phẩm mới
                a(href=`${prefixAdmin}/products` class="btn btn-sm btn-light")
                    i(class="fas fa-arrow-left me-1")
                    | Quay lại

            div(class="card-body")
                form(
                    action=`${prefixAdmin}/products/create`
                    id="form-create-product"
                    method="POST"
                    enctype="multipart/form-data"
                )
                    div(class="row")
                        div(class="col-md-8")
                            div(class="form-group mb-3")
                                label(for="title" class="form-label fw-bold") Tiêu đề
                                input(
                                    type="text"
                                    class="form-control"
                                    id="title"
                                    name="title"
                                    placeholder="Nhập tên sản phẩm"
                                    required
                                )
                            
                            div(class="form-group mb-3")
                                label(for="desc" class="form-label fw-bold") Mô tả
                                textarea(
                                    class="form-control"
                                    id="desc"
                                    name="description"
                                    rows="5"
                                    placeholder="Mô tả chi tiết sản phẩm"
                                )
                        
                        div(class="col-md-4")
                            div(class="form-group mb-3" upload-image)
                                label(for="thumbnail" class="form-label d-block fw-bold") Ảnh sản phẩm
                                input(
                                    type="file"
                                    class="form-control mb-2"
                                    id="thumbnail"
                                    name="thumbnail"
                                    accept="image/*"
                                    upload-image-input
                                )
                                div(class="image-preview-wrapper position-relative")
                                    img(
                                        src=""
                                        upload-image-preview
                                        class="image-preview"
                                    )
                                    span(close-image-preview class="btn btn-danger btn-sm position-absolute top-0 start-0 translate-middle badge rounded-pill" style="display: none; cursor: pointer;") 
                                        i(class="fas fa-times")

                            div(class="form-group mb-3")
                                label(for="position" class="form-label fw-bold") Vị trí
                                input(
                                    type="number"
                                    class="form-control"
                                    id="position"
                                    name="position"
                                    placeholder="Tự động tăng"
                                    min="1"
                                )

                    div(class="row")
                        div(class="col-md-4")
                            div(class="form-group mb-3")
                                label(for="price" class="form-label fw-bold") Giá
                                div(class="input-group")
                                    span(class="input-group-text") $
                                    input(
                                        type="number"
                                        class="form-control"
                                        id="price"
                                        name="price"
                                        value="0"
                                        min="0"
                                    )
                        div(class="col-md-4")
                            div(class="form-group mb-3")
                                label(for="discount" class="form-label fw-bold") Giảm giá
                                div(class="input-group")
                                    input(
                                        type="number"
                                        class="form-control"
                                        id="discount"
                                        name="discountPercentage"
                                        value="0"
                                        min="0"
                                        max="100"
                                    )
                                    span(class="input-group-text") %
                        div(class="col-md-4")
                            div(class="form-group mb-3")
                                label(for="stock" class="form-label fw-bold") Số lượng
                                input(
                                    type="number"
                                    class="form-control"
                                    id="stock"
                                    name="stock"
                                    value="0"
                                    min="0"
                                )

                    div(class="form-group mb-4")
                        label(class="form-label d-block fw-bold") Trạng thái
                        div(class="form-check form-check-inline")
                            input(
                                type="radio"
                                class="form-check-input"
                                id="statusActive"
                                name="status"
                                value="active"
                                checked
                            )
                            label(for="statusActive" class="form-check-label text-success") Hoạt động 
                        div(class="form-check form-check-inline")
                            input(
                                type="radio"
                                class="form-check-input"
                                id="statusInActive"
                                name="status"
                                value="inactive"
                            )
                            label(for="statusInActive" class="form-check-label text-danger") Dừng hoạt động
                    
                    hr

                    div(class="form-group mb-0 text-end")
                        button(
                            type="submit"
                            class="btn btn-primary btn-lg px-5 shadow-sm"
                        ) 
                            i(class="fas fa-save me-2")
                            | Tạo mới sản phẩm

    script(src="/admin/js/product.js")