extends ../../layouts/default.pug

include ../../mixins/filter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/alert.pug

block main

    +alert-success(3000)
    +alert-error(3000)

    h1 List Products
    .card.mb-3
        .card-header Filter and Search
        .card-body
            .d-flex.flex-wrap.align-items-center.gap-2
                .input-group.input-group-sm.flex-grow-1.me-2
                    +search()

                // Buttons for medium+ screens (wrap automatically when too many)
                .d-none.d-md-flex.flex-wrap.gap-2(
                    role="group" 
                    aria-label="Filter buttons"
                ) 
                    +filter-status(filterStatus)

                // Dropdown for small screens
                .dropdown.d-md-none
                    button.btn.btn-sm.btn-outline-secondary.dropdown-toggle(
                        type="button" 
                        id="filterDropdown" 
                        data-bs-toggle="dropdown" 
                        aria-expanded="false"
                    ) Filter
                    ul.dropdown-menu(
                        aria-labelledby="filterDropdown"
                    )
                        each item in filterStatus
                            li
                                a.dropdown-item(
                                    href="#" 
                                    data-status=item.status
                                )= item.name

            .d-flex.align-items-center.gap-2.mt-2(sort)
                label.form-label.mb-0.text-nowrap.fw-semibold(for="sort-select") Sort
                select#sort-select.form-select.form-select-sm(
                    name="sort"
                    sort-select
                    style="max-width: 220px;"
                )
                    option(value="") -- Default --
                    option(value="position-desc") Position desc
                    option(value="position-asc") Position asc
                    option(value="price-desc") Price desc
                    option(value="price-asc") Price asc
                    option(value="title-asc") Title A → Z
                    option(value="title-desc") Title Z → A
                button.btn.btn-sm.btn-outline-danger(sort-clear) Delete

    .card.mb-3
        .card-header List
            .card-body
                .row 
                    .col-8 
                        +formChangeMulti(`${prefixAdmin}/products/change-multi`)
                    .col-4
                        a(
                            href=`${prefixAdmin}/products/create`
                            class="btn btn-success fw-bold float-end"
                        ) + Create
                table(
                    class="table table-hover table-sm table-bordered"
                        checkbox-multi
                )
                    thead
                        tr
                            th
                                input(type="checkbox" id="check-all")
                            th No.
                            th Image
                            th Title
                            th Price
                            th Position
                            th Status
                            th Actions
                    tbody
                        each item, index in products
                            tr
                                td
                                    input(
                                        type="checkbox" 
                                        name="id" 
                                        value=item.id
                                    )
                                td= index + 1
                                td
                                    if item && item.thumbnail
                                        img(
                                            src=item.thumbnail 
                                            alt=item.title
                                        )
                                    else
                                        | -
                                td= item && item.title
                                td= item && item.price
                                td
                                    input(
                                        type="number"
                                        value=item.position
                                        style="width: 60px;"
                                        min="1"
                                        name="position"
                                    )
                                td
                                    if (item && item.status === "active")
                                        span(
                                            role="button"
                                            data-status=item.status
                                            data-id=item._id
                                            button-change-status
                                            class="badge bg-success"
                                        ) Active
                                    else
                                        span(
                                            role="button"
                                            data-status=item.status
                                            data-id=item._id
                                            button-change-status
                                            class="badge bg-danger"
                                        ) Inactive
                                td(class="d-flex flex-column gap-1")
                                    a(
                                        href=`${prefixAdmin}/products/detail/${item._id}`
                                        type="button" 
                                        class="btn btn-secondary btn-sm"
                                    ) Detail
                                    a(
                                        href=`${prefixAdmin}/products/edit/${item._id}`
                                        type="button" 
                                        class="btn btn-warning btn-sm"
                                    ) Edit
                                    a(
                                        href=`${prefixAdmin}/products/delete/${item._id}`
                                        type="button" 
                                        class="btn btn-danger btn-sm"
                                        button-delete
                                        data-id=item._id
                                    ) Delete

                //- Pagination (mixin)
                +pagination(pagination, baseQuery)

                form(
                    action=""
                    method="POST"
                    id="form-change-status"
                    data-path=`${prefixAdmin}/products/change-status/`
                )
                    // include override field so server can treat POST as PATCH
                    input(type="hidden" name="_method" value="PATCH")
                script(src="/admin/js/product.js")
