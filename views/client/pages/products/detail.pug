extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container.my-5
    .row
      // Left: Image
      .col-md-6
        .border.rounded-3.p-4.bg-white.shadow-sm.text-center
          img(
            src=product.thumbnail
            alt=product.title
            class="img-fluid"
            style="max-height: 500px; object-fit: contain;"
          )
      
      // Right: Info
      .col-md-6.ps-md-5
        h1.fw-bold.mb-3 #{product.title}

        if (product.category)
          p.text-muted.mb-4
            | Danh mục: 
            a(href=`/products/${product.category.slug}`, class="text-primary text-decoration-none fw-semibold") #{product.category.title}

        .d-flex.align-items-baseline.mb-4
          h2.text-danger.fw-bold.mb-0 #{product.priceNew}$
          if (product.price)
            span.text-muted.text-decoration-line-through.ms-3.fs-4 #{product.price}$
          if (product.discountPercentage)
            span.ms-3.badge.bg-warning.text-dark.fs-6 -#{product.discountPercentage}%

        if (product.stock)
          p.mb-4
            span.text-muted Trình trạng: 
            span.badge.bg-success Còn hàng (#{product.stock})
        else 
          p.mb-4
            span.text-muted Trình trạng: 
            span.badge.bg-danger Hết hàng

        form(
          action=`/cart/add/${product.id}`
          method="POST"
          class="row g-3 align-items-center"
        )
          .col-auto
            input(
              class="form-control"
              type="number"
              name="quantity"
              value="1"
              min="1"
              max=product.stock
              style="width: 80px;"
            )
          .col-auto
            button(
              type="submit"
              class="btn btn-success btn-lg px-5 fw-bold"
            ) THÊM VÀO GIỎ HÀNG

    // Bottom: Description
    .row.mt-5
      .col-12
        .card.border-0.shadow-sm
          .card-header.bg-white.py-3
            h4.mb-0.fw-bold Mô tả sản phẩm
          .card-body.p-4
            .product-content
              | !{product.description}